{
  "environment": "local",
  "baseUrl": "http://localhost:3000",
  "browser": {
    "name": "chrome",
    "headless": false,
    "windowSize": { "width": 1920, "height": 1080 },
    "args": []
  },
  "timeouts": {
    "implicit": 0,
    "explicit": 10000,
    "pageLoad": 30000,
    "script": 10000,
    "polling": 200
  },
  "retry": {
    "maxAttempts": 3,
    "backoffMs": 1000,
    "backoffMultiplier": 2
  },
  "parallel": {
    "enabled": false,
    "workers": 1
  },
  "logging": {
    "level": "debug",
    "structured": false
  },
  "plugins": {
    "enabled": ["metrics"]
  }
}
