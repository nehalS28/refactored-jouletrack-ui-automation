{
  "environment": "production",
  "baseUrl": "${PRODUCTION_BASE_URL}",
  "browser": {
    "name": "chrome",
    "headless": true,
    "windowSize": { "width": 1920, "height": 1080 },
    "args": ["--no-sandbox", "--disable-dev-shm-usage", "--disable-gpu"]
  },
  "timeouts": {
    "implicit": 0,
    "explicit": 20000,
    "pageLoad": 60000,
    "script": 20000,
    "polling": 300
  },
  "retry": {
    "maxAttempts": 2,
    "backoffMs": 2000,
    "backoffMultiplier": 2
  },
  "parallel": {
    "enabled": true,
    "workers": 1
  },
  "logging": {
    "level": "warn",
    "structured": true
  },
  "plugins": {
    "enabled": ["metrics", "allure", "zephyr"],
    "metrics": {
      "dbPath": "./data/metrics.db",
      "slowLocatorThresholdMs": 500,
      "performanceRegressionThreshold": 0.5
    },
    "allure": {
      "outputDir": "./reports/allure-results",
      "screenshotOnFailure": true
    },
    "zephyr": {
      "projectKey": "${ZEPHYR_PROJECT_KEY}",
      "batchSize": 100
    }
  }
}
