{
  "environment": "ci",
  "baseUrl": "${BASE_URL}",
  "browser": {
    "name": "chrome",
    "headless": true,
    "windowSize": { "width": 1920, "height": 1080 },
    "args": ["--no-sandbox", "--disable-dev-shm-usage"]
  },
  "timeouts": {
    "implicit": 0,
    "explicit": 10000,
    "pageLoad": 30000,
    "script": 10000,
    "polling": 200
  },
  "retry": {
    "maxAttempts": 3,
    "backoffMs": 1000,
    "backoffMultiplier": 2
  },
  "parallel": {
    "enabled": true,
    "workers": 4
  },
  "logging": {
    "level": "info",
    "structured": true
  },
  "plugins": {
    "enabled": ["metrics", "allure"],
    "metrics": {
      "dbPath": "./data/metrics.db",
      "slowLocatorThresholdMs": 500,
      "performanceRegressionThreshold": 0.5
    },
    "allure": {
      "outputDir": "./reports/allure-results",
      "screenshotOnFailure": true
    }
  }
}
