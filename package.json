{
  "name": "@jira2test/ui-automation",
  "version": "1.0.0",
  "description": "Optimized UI automation framework with worker-scoped architecture, typed locators, and plugin system",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "generate:locators": "tsx cli/index.ts generate:locators",
    "cli": "tsx cli/index.ts"
  },
  "dependencies": {
    "selenium-webdriver": "^4.18.1",
    "@cucumber/cucumber": "^10.3.1",
    "better-sqlite3": "^9.4.3",
    "commander": "^12.0.0",
    "yaml": "^2.4.1",
    "pixelmatch": "^5.3.0",
    "pngjs": "^7.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.9",
    "@types/node": "^20.11.24",
    "@types/selenium-webdriver": "^4.1.22",
    "@types/pngjs": "^6.0.4",
    "typescript": "^5.4.2",
    "vitest": "^1.3.1",
    "@vitest/coverage-v8": "^1.3.1",
    "tsx": "^4.7.1",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "prettier": "^3.2.5",
    "fast-check": "^3.15.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "ui-automation",
    "selenium",
    "cucumber",
    "typescript",
    "testing"
  ],
  "author": "QA Team",
  "license": "MIT"
}
