# UI Automation Framework Environment Configuration
# Migrated from jouletrack-ui-automation framework
# Last Updated: March 12, 2026

# ============================================
# APPLICATION URLS
# ============================================
# Base URL for the application under test
BASE_URL=https://staging.smartjoules.org
# Alternative production URL (uncomment to use)
# BASE_URL=https://smartjoules.org

# ============================================
# TEST SITES
# ============================================
# Default test site ID
SITE=sjo-del
# Real site ID for specific tests
REAL_SITE=gknmh

# ============================================
# TEST CREDENTIALS (REQUIRED)
# ============================================
# Valid test user email - REPLACE WITH ACTUAL VALUE
VALID_EMAIL=test@smartjoules.com
# Valid test user password - REPLACE WITH ACTUAL VALUE
VALID_PASSWORD=TestPassword123

# ============================================
# ENCRYPTION & SECURITY
# ============================================
# CryptoJS secret key for encryption - REPLACE WITH ACTUAL VALUE
CRYPTOJS_SECRET_KEY=your-secret-key-here

# ============================================
# BROWSER CONFIGURATION
# ============================================
# Browser to use for tests (chrome, firefox, edge, safari)
BROWSER=chrome
# Run browser in headless mode (true/false)
HEADLESS=false

# ============================================
# TEST EXECUTION SETTINGS
# ============================================
# Number of parallel workers (1-8)
PARALLEL_WORKERS=4
# Test timeout in milliseconds
TEST_TIMEOUT=60000
# Page load timeout in milliseconds
PAGE_LOAD_TIMEOUT=30000

# ============================================
# ALLURE REPORTING
# ============================================
# Enable Allure reporting (true/false)
ALLURE_ENABLED=true
# Allure results directory
ALLURE_RESULTS_DIR=allure-results
# Allure report directory
ALLURE_REPORT_DIR=allure-report

# ============================================
# AWS S3 CONFIGURATION (Optional - for report upload)
# ============================================
# AWS Profile name
AWS_PROFILE=
# AWS Access Key ID
AWS_ACCESS_KEY_ID=
# AWS Secret Access Key
AWS_SECRET_ACCESS_KEY=
# AWS Session Token (if using temporary credentials)
AWS_SESSION_TOKEN=
# AWS Region
AWS_REGION=us-west-2
# S3 Bucket name for report storage
S3_BUCKET_NAME=dejoule-automation-report

# ============================================
# ZEPHYR INTEGRATION (Optional)
# ============================================
# Jira Project Key
PROJECT_KEY=
# Zephyr API Token
ZEPHYR_API_TOKEN=
# Jira API Token
JIRA_API_TOKEN=
# Jira Base URL
JIRA_BASE_URL=
# Jira Email
JIRA_EMAIL=
# Assignee Account ID
ASSIGNEE_ACCOUNT_ID=

# ============================================
# LOGGING & DEBUGGING
# ============================================
# Log level (error, warn, info, debug, trace)
LOG_LEVEL=info
# Enable screenshot on failure (true/false)
SCREENSHOT_ON_FAILURE=true
# Enable video recording (true/false)
VIDEO_RECORDING=false

# ============================================
# NETWORK & PERFORMANCE
# ============================================
# Network throttling (none, slow-3g, fast-3g)
NETWORK_THROTTLE=none
# Enable performance metrics collection (true/false)
COLLECT_METRICS=true

# ============================================
# NOTES
# ============================================
# 1. REQUIRED fields must be filled before running tests
# 2. Copy actual values from jouletrack-ui-automation/configuration/.env
# 3. Never commit this file with real credentials to version control
# 4. Use .env.example for template without sensitive data
